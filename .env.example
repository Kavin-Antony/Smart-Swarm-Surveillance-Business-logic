# ── Node Identity ─────────────────────────────────────────────────────────
# Unique ID for this camera node (must differ on each laptop)
NODE_ID=node_1

# ── Video Source ──────────────────────────────────────────────────────────
# Leave RTSP_URL empty to fall back to webcam (WEBCAM_INDEX)
RTSP_URL=rtsp://192.168.1.100:554/stream1
WEBCAM_INDEX=0

# ── YOLO ──────────────────────────────────────────────────────────────────
# yolov8n.pt (nano) is recommended for CPU-only laptops
YOLO_MODEL=yolov8n.pt
# Run detection once every N frames (higher = less CPU)
DETECTION_INTERVAL=5

# ── MQTT ──────────────────────────────────────────────────────────────────
# IP of ANY laptop running the broker (e.g. mosquitto on that machine)
MQTT_BROKER=192.168.1.50
MQTT_PORT=1883

# ── Bandwidth Negotiation ─────────────────────────────────────────────────
# Total shared uplink bandwidth across all nodes (Mbps)
TOTAL_BANDWIDTH=10.0
# Seconds without heartbeat before a peer is considered dead
NODE_TIMEOUT=8.0

# ── Flask Dashboard ───────────────────────────────────────────────────────
FLASK_PORT=5000
